{
  "name": "sync-server",
  "type": "module",
  "version": "0.0.50",
  "private": true,
  "scripts": {
    "test": "bun run ./src/utils/env.ts",
    "dev": "PORT=$SYNC_SERVER_PORT bun run --watch ./src/index.ts",
    "build": "bun run ./src/utils/env.ts && bun build --minify-whitespace --minify-syntax --target bun --outdir ./dist --sourcemap ./src/index.ts",
    "start": "bun run ./dist/index.js",
    "format": "oxfmt --write ./src",
    "lint": "oxlint --fix"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/cron": "^1.4.2",
    "@elysiajs/server-timing": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@libsql/client": "^0.17.3",
    "@tanstack/pacer": "^0.21.1",
    "@tanstack/solid-pacer": "^0.21.1",
    "@tanstack/solid-query-devtools": "^5.101.0",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "ethers": "^6.16.0",
    "hlc": "workspace:*",
    "merkle-tree": "workspace:*",
    "nanoid": "^5.1.11",
    "proto": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@dword-design/eslint-plugin-import-alias": "^8.1.8",
    "@eslint/compat": "^2.1.0",
    "@rthings/config": "workspace:*",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "typescript-eslint": "^8.61.0"
  },
  "module": "src/index.js"
}
