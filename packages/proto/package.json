{
  "name": "proto",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "npm run proto:generate && tsdown --out-dir ./dist",
    "proto:generate": "buf generate",
    "dev": "npm run build -- --watch src",
    "lint": "eslint --fix src",
    "format": "echo no formatting necessary"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@bufbuild/buf": "^1.70.0",
    "@bufbuild/protobuf": "^2.12.0",
    "@bufbuild/protoc-gen-es": "^2.12.0"
  }
}
