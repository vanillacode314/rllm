{
  "name": "object-pool",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "author": "Raqueebuddin Aziz",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --out-dir ./dist",
    "dev": "npm run build -- --watch src",
    "lint": "oxlint --fix",
    "format": "oxfmt",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@rthings/config": "workspace:*",
    "@types/node": "^25.9.3",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
